<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">#E65100</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- Background and Window Colors -->
        <item name="android:windowBackground">@color/bg_light</item>
    </style>
    
    <!-- Splash Screen theme -->
    <style name="Theme.MyApplication.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:statusBarColor">#121212</item>
    </style>
</resources>
