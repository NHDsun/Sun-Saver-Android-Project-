<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- TOOLBAR CUSTOM -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/card_bg_light"
        android:elevation="4dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentLeft="true"
            android:layout_centerInParent="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Quay lại"
            app:tint="@color/text_primary_light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thống kê tài chính"
            android:textColor="@color/text_primary_light"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CARD SỐ DƯ TỔNG QUAN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg_light"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SỐ DƯ HIỆN TẠI"
                        android:textColor="@color/text_secondary_light"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tv_stats_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ₫"
                        android:textColor="@color/text_primary_light"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <!-- PHÂN SPLIT TỶ LỆ TRỰC QUAN (Sử dụng ProgressBar tuỳ biến) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TỶ LỆ THU / CHI"
                        android:textColor="@color/text_secondary_light"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginTop="20dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tv_ratio_income_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thu nhập: --%"
                            android:textColor="@color/color_income"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_ratio_expense_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chi tiêu: --%"
                            android:textColor="@color/color_expense"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Thanh biểu đồ tỉ lệ 2 màu song song xếp chồng -->
                    <ProgressBar
                        android:id="@+id/pb_ratio"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:max="100"
                        android:progress="50"
                        android:progressDrawable="@drawable/bg_statistics_progress" />

                    <!-- Chú giải số tiền cụ thể -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng Thu"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_stats_income"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/color_income"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="right">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng Chi"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_stats_expense"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/color_expense"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CARD THỐNG KÊ CHI TIÊU THEO TỪNG DANH MỤC (MÓC NỐI THÙNG RÁC SQLITE) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHI TIÊU THEO DANH MỤC"
                android:textColor="@color/text_secondary_light"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.05" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- ĂN UỐNG -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍔 Ăn uống"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_cat_food_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pb_cat_food"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#F97316" /> <!-- M3 Orange custom tint -->
                    </LinearLayout>

                    <!-- HỌC TẬP -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📚 Học tập"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_cat_study_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pb_cat_study"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#3B82F6" /> <!-- Blue -->
                    </LinearLayout>

                    <!-- GIẢI TRÍ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎮 Giải trí"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_cat_entertainment_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pb_cat_entertainment"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#EC4899" /> <!-- Pink/Magenta -->
                    </LinearLayout>

                    <!-- DI CHUYỂN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚗 Di chuyển"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_cat_transport_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pb_cat_transport"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#06B6D4" /> <!-- Cyan -->
                    </LinearLayout>

                    <!-- KHÁC -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰 Khác"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_cat_other_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₫"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pb_cat_other"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#8B5CF6" /> <!-- Purple -->
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
