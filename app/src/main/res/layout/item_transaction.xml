<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="4dp"
    android:layout_marginRight="4dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="?android:attr/selectableItemBackground">

        <!-- VÒNG TRÒN ICON BIỂU TƯỢNG (DÙNG EMOJI VẼ NỔI) -->
        <LinearLayout
            android:id="@+id/layout_category_icon_holder"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:background="@drawable/bg_category_circle_gray"
            android:orientation="horizontal"
            android:layout_marginRight="14dp">

            <TextView
                android:id="@+id/tv_category_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- THÔNG TIN TÊN GIAO DỊCH, DANH MỤC, NGÀY THÁNG -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Học phí học kỳ II"
                android:textColor="@color/text_primary_light"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="3dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_item_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Học tập"
                    android:textColor="@color/text_secondary_light"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/text_secondary_light"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_item_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25/05/2026"
                    android:textColor="@color/text_secondary_light"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- SỐ TIỀN THU HOẶC CHI (TÙY KIỂU HIỂN THỊ MÀU KHÁC BIỆT CHUYÊN NGHIỆP) -->
        <TextView
            android:id="@+id/tv_item_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-350.000 ₫"
            android:textColor="@color/text_primary_light"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginLeft="12dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
