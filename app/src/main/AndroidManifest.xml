<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        
        <!-- MÀN HÌNH CHÀO MỪNG (LAUNCHER ĐỘC LẬP) -->
        <activity
            android:name="com.example.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MÀN HÌNH ĐĂNG NHẬP (LOGIN SCREEN) -->
        <activity
            android:name="com.example.activities.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:windowSoftInputMode="adjustResize" />

        <!-- MÀN HÌNH ĐĂNG KÝ (REGISTER SCREEN) -->
        <activity
            android:name="com.example.activities.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:windowSoftInputMode="adjustResize" />

        <!-- MÀN HÌNH TRANG CHỦ CHÍNH (MAIN ACTIVITY) -->
        <activity
            android:name="com.example.activities.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:windowSoftInputMode="adjustPan" />

        <!-- MÀN HÌNH THÊM / SỬA GIAO DỊCH -->
        <activity
            android:name="com.example.activities.AddTransactionActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:windowSoftInputMode="adjustResize" />

        <!-- MÀN HÌNH THỐNG KÊ CHI TIÊU -->
        <activity
            android:name="com.example.activities.StatisticsActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />

    </application>

</manifest>
